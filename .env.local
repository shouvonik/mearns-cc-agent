# ─────────────────────────────────────────────────────────────────────────────
# Mearns CC Agent — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PlayHQ ────────────────────────────────────────────────────────────────────
# API key from the PlayHQ partner portal (Cricket Scotland)
PLAYHQ_API_KEY=

# The organisation ID for Mearns Cricket Club in PlayHQ
# Find it via the PlayHQ admin portal or API
PLAYHQ_ORG_ID=

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Google Photos ─────────────────────────────────────────────────────────────
# OAuth2 access token for the Google Photos Library API
# Obtain via OAuth2 flow with scope: https://www.googleapis.com/auth/photoslibrary.readonly
GOOGLE_PHOTOS_ACCESS_TOKEN=

# The Google Photos album ID to pull match photos from
# Find the album ID in the album URL or via the API: GET /v1/albums
GOOGLE_PHOTOS_ALBUM_ID=

# ── Facebook ──────────────────────────────────────────────────────────────────
# The numeric ID of the Mearns CC Facebook Page
# Found at facebook.com/<page>/about or via Graph API: GET /me/accounts
FACEBOOK_PAGE_ID=

# A long-lived Page Access Token with pages_manage_posts permission
# Generate via Meta for Developers: https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Instagram ─────────────────────────────────────────────────────────────────
# Instagram Business Account ID linked to the Facebook Page
# Found via Graph API: GET /{page-id}?fields=instagram_business_account
INSTAGRAM_ACCOUNT_ID=
# (reuses FACEBOOK_PAGE_ACCESS_TOKEN — no additional token needed)

# ── Twitter / X ───────────────────────────────────────────────────────────────
# OAuth 1.0a credentials from https://developer.twitter.com/en/portal/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
